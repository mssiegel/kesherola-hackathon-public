# Copy to .env and fill in your keys. This is the ONLY auth source for the app.

# Get your Dial key (starts with "sk_live_") from https://getdial.ai
DIAL_API_KEY=sk_live_REPLACE_WITH_YOUR_DIAL_KEY

# Preferred key for transcript assessment. Use either OPENAI_API_KEY or CODEX_API_KEY.
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
CODEX_API_KEY=

# Optional fallback for transcript assessment. From https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY

# Optional:
# PORT=8000
# DIAL_BASE_URL=https://getdial.ai
# DIAL_NUMBER_ID=          # default sending number id; falls back to your first number
# ASSESS_MODEL=gpt-5.5
